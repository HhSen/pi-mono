{
	"name": "@mariozechner/pi-gui-agent",
	"version": "0.58.4",
	"description": "Stateless HTTP server for streaming pi coding-agent sessions",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": [
		"dist",
		"README.md"
	],
	"scripts": {
		"clean": "shx rm -rf dist",
		"build": "tsgo -p tsconfig.build.json",
		"dev": "tsx watch src/main.ts",
		"start": "node dist/main.js",
		"prepublishOnly": "npm run clean && npm run build"
	},
	"keywords": [
		"ai",
		"agent",
		"express",
		"sse"
	],
	"author": "Mario Zechner",
	"license": "MIT",
	"dependencies": {
		"@mariozechner/pi-ai": "^0.58.4",
		"@mariozechner/pi-coding-agent": "^0.58.4",
		"express": "^5.2.1"
	},
	"devDependencies": {
		"@types/express": "^5.0.3",
		"@types/node": "^24.3.0",
		"shx": "^0.4.0",
		"tsx": "^4.20.3",
		"typescript": "^5.7.3"
	},
	"engines": {
		"node": ">=20.0.0"
	}
}
